{
  "suite_name": "M1-arquetipo-go-no-go-brasil-v1",
  "objective": "Validar se o formulario novo consegue formar um arquetipo deterministico e valido para 15 cenarios reais e comuns no Brasil, sem inferencia livre.",
  "global_rules": {
    "must_show_arquetipo_preview_on_final_step": true,
    "must_block_if_status_arquetipo_not_valido": true,
    "must_not_depend_on_free_text_for_classification": true,
    "must_recalculate_confidence_formula": true,
    "go_no_go_rule": "GO somente se os 15 cenarios resultarem em status_arquetipo=valido com os campos estruturados previstos."
  },
  "core_required_fields": [
    "cnpj",
    "natureza_juridica",
    "nome_empresarial",
    "natureza_operacao_principal",
    "operacoes_secundarias",
    "fontes_receita",
    "tipo_objeto_economico",
    "posicao_cadeia_economica",
    "cnae_principal_confirmado",
    "possui_bens",
    "possui_servicos",
    "abrangencia_operacional",
    "opera_multiplos_estados",
    "uf_principal_operacao",
    "regime_tributario_atual",
    "faixa_faturamento_anual",
    "porte_empresa",
    "tipo_cliente_predominante",
    "setor_regulado",
    "atua_importacao",
    "atua_exportacao",
    "opera_territorio_incentivado",
    "possui_regime_especial_negocio",
    "integra_grupo_economico",
    "analise_1_cnpj_operacional",
    "nivel_analise"
  ],
  "conditional_rules": [
    { "if": "possui_bens == true", "then_required": ["ncms_principais"] },
    { "if": "possui_servicos == true", "then_required": ["nbss_principais"] },
    { "if": "opera_multiplos_estados == true", "then_required": ["possui_filial_outra_uf"] },
    { "if": "possui_filial_outra_uf == true", "then_required": ["estrutura_operacao"] },
    { "if": "atua_importacao == true or atua_exportacao == true", "then_required": ["papel_comercio_exterior"] },
    { "if": "setor_regulado == true", "then_required": ["orgao_regulador_principal", "subnatureza_setorial", "tipo_operacao_especifica", "papel_operacional_especifico"] },
    { "if": "opera_territorio_incentivado == true", "then_required": ["tipo_territorio_incentivado"] },
    { "if": "possui_regime_especial_negocio == true", "then_required": ["tipo_regime_especial"] },
    { "if": "natureza_operacao_principal in ['Transporte', 'Agro'] or operacoes_secundarias contains 'Logistica'", "then_required": ["realiza_operacao_propria_terceiros"] },
    { "if": "integra_grupo_economico == true and analise_1_cnpj_operacional == false", "then_block": true }
  ],
  "tests": [
