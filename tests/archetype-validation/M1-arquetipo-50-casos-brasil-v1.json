{
  "suite_name": "M1-arquetipo-50-casos-brasil-v1",
  "phase": "PRE_M1_EXPLORACAO",
  "objective": "Rodar 50 cenarios de negocio, gerar o output do arquetipo para cada um e devolver JSON consolidado para avaliacao do P.O./consultor.",
  "economic_basis": {
    "reasoning": "A amostra deve sobreponderar Servicos, depois Industria, depois Agro, para refletir a composicao do PIB brasileiro.",
    "reference_2024": {
      "PIB_total_R$": "11.7 tri",
      "Servicos_R$": "7.0 tri",
      "Industria_R$": "2.5 tri",
      "Agropecuaria_R$": "655.3 bi"
    },
    "target_distribution_50": {
      "servicos": 30,
      "industria": 13,
      "agro": 7
    }
  },
  "rules_for_claude": {
    "do_not_code_product": true,
    "do_not_infer_with_llm": true,
    "use_structured_rules_only": true,
    "goal_is_validation_not_implementation": true,
    "must_return_json_only": true,
    "for_each_case_return": [
      "id",
      "scenario_name",
      "status",
      "missing_fields",
      "opened_blocks",
      "blocking_rules_triggered",
      "arquetipo_output",
      "confidence_on_archetype_structure",
      "notes"
    ],
    "status_values": ["PASS", "FAIL", "BLOCKED", "AMBIGUOUS"],
    "arquetipo_output_minimum_fields": [
      "natureza_da_operacao",
      "fontes_de_receita",
      "tipo_de_objeto_economico",
      "posicao_na_cadeia_economica",
      "cnae_principal_confirmado",
      "ncm_produtos",
      "nbs_servicos",
      "abrangencia_territorial",
      "regime_tributario",
      "porte_empresa",
      "orgao_regulador",
      "subnatureza_setorial",
      "papel_operacional",
      "tipo_operacao_especifica",
      "papel_comercio_exterior",
      "tipo_territorio_incentivado",
      "tipo_regime_especial",
      "status_arquetipo"
    ]
  },
  "coverage_expectation": {
    "must_cover_rules": [
      "bens -> abre NCM",
      "servicos -> abre NBS",
      "multiestado -> territorial_expandido",
      "setor_regulado -> regulatorio",
      "importacao_ou_exportacao -> comercio_exterior",
      "territorio_incentivado -> territorio_incentivado",
      "regime_especial -> regimes_especiais",
      "multi_cnpj_fora_escopo -> bloqueio"
    ],
    "must_include_negative_controls": [
      "casos com apenas bens",
      "casos com apenas servicos",
      "casos mistos",
      "casos regulados",
      "casos nao regulados",
      "casos com importacao/exportacao",
      "casos sem importacao/exportacao",
      "caso bloqueado multi-CNPJ"
    ]
  },
